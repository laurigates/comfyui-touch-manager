# Keep the Docker build context lean. The pack source (src/, package.json,
# bun.lock, tsconfig/biome) + the screenshots/ dir are all the build needs;
# node_modules and web/dist are regenerated in-image by `bun install` +
# `bun run build`.
.git/
.github/
.venv/
.pytest_cache/
.ruff_cache/
node_modules/
web/dist/
docs/
tests/
uv.lock
*.egg-info/
__pycache__/
.DS_Store
.vscode/
.idea/
.claude/
TODO.local.md
NOTES.local.md
